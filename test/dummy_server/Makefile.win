SHELL := cmd.exe
.SHELLFLAGS := /C

CC ?= gcc
CFLAGS ?= -std=c11 -O2 -Wall -Wextra -pedantic
TARGET ?= dummy_server.exe
SRC := dummy_server.c

.PHONY: all run clean

all: $(TARGET)

$(TARGET): $(SRC)
	$(CC) $(CFLAGS) -o $(TARGET) $(SRC)

run: $(TARGET)
	$(TARGET)

clean:
	if exist $(TARGET) del /Q $(TARGET)